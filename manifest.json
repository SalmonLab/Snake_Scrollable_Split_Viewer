{
  "manifest_version": 3,
  "name": "SplitStream Browser",
  "version": "0.1.0",
  "description": "Display one page as synchronized multi-column flow (2 or 3 columns).",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "SplitStream",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-split-off": {
      "suggested_key": {
        "default": "Shift+1",
        "mac": "Shift+1"
      },
      "description": "SplitStream: Off"
    },
    "set-split-2": {
      "suggested_key": {
        "default": "Shift+2",
        "mac": "Shift+2"
      },
      "description": "SplitStream: 2 columns"
    },
    "set-split-3": {
      "suggested_key": {
        "default": "Shift+3",
        "mac": "Shift+3"
      },
      "description": "SplitStream: 3 columns"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
