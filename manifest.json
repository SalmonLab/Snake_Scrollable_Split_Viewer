{
    "manifest_version":  3,
    "name":  "Snake-Scrollable Split Viewer",
    "version":  "0.1.0",
    "description":  "Snake-style synchronized multi-column scrolling for easier reading.",
    "permissions":  [
                        "storage",
                        "tabs"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "action":  {
                   "default_title":  "Snake-Scrollable Split Viewer",
                   "default_popup":  "popup.html"
               },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "icons":  {
                  "16":  "icons/icon-16.png",
                  "128":  "icons/icon-128.png",
                  "32":  "icons/icon-32.png",
                  "64":  "icons/icon-64.png"
              }
}
