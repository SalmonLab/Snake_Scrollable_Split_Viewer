{
  "manifest_version": 3,
  "name": "Snake-Scrollable Split Viewer",
  "version": "0.1.0",
  "description": "Snake-style synchronized multi-column scrolling for easier reading.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Snake-Scrollable Split Viewer",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
