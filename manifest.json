{
    "manifest_version":  3,
    "name":  "Snake-Scrollable Split Viewer",
    "version":  "0.1.0",
    "description":  "Snake-style synchronized multi-column scrolling for easier reading.",
    "permissions":  [
                        "storage",
                        "tabs"
                    ],
    "host_permissions":  [
                             "http://*/*", "https://*/*"],
    "action":  {
                   "default_title":  "Snake-Scrollable Split Viewer",
                   "default_popup":  "popup.html"
               },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "http://*/*", "https://*/*"],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "icons":  {
                  "16":  "snake_scrollable_split_viewer_icons/snake_scrollable_split_viewer_icon_16x16.png",
                  "32":  "snake_scrollable_split_viewer_icons/snake_scrollable_split_viewer_icon_32x32.png",
                  "64":  "snake_scrollable_split_viewer_icons/snake_scrollable_split_viewer_icon_64x64.png",
                  "128":  "snake_scrollable_split_viewer_icons/snake_scrollable_split_viewer_icon_128x128.png"
              }
}



